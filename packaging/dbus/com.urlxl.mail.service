# This template is inert until a build actually installs the binary at
# Exec=. It activates nothing under a plain in-tree/dev build -- only after
# `make install` (or a Flatpak install, which remaps the path via its own
# manifest) puts llamamail at /usr/bin/llamamail. Dev/proof runs that need
# D-Bus activation locally use a separate, uncommitted copy of this file
# pointing at the in-tree build output path instead.
[D-BUS Service]
Name=com.urlxl.mail
Exec=/usr/bin/llamamail
